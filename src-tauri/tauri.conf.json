{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hype",
  "version": "2.0.0",
  "identifier": "com.overpowered.hype",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Hype",
        "width": 900,
        "height": 600,
        "minWidth": 900,
        "minHeight": 600,
        "center": false,
        "resizable": true,
        "decorations": true,
        "visible": false,
        "backgroundColor": "#0e0e10"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/ffmpeg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "hype"
        ]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUwNkYwODE3RENDRDdCMzUKUldRMWU4M2NGd2h2NEpMTkhnRjFIaTltclI1Y1dBZVpTZkhlTG03bHVtUnA1cHFqSW1JbytrZEYK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
