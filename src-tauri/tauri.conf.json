{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "hype",
  "version": "0.1.0",
  "identifier": "com.overpowered.hype",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "hype",
        "width": 900,
        "height": 600,
        "minWidth": 900,
        "minHeight": 600,
        "center": false,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
    "bundle": {
      "active": true,
      "targets": "all",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "createUpdaterArtifacts": true
    },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["hype"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc4RUIyRDVCMTQ3MzcyMkQKUldRdGNuTVVXeTNyZUFsMFdmMy9BaTF1Z1FmZW5vOEhHVlhqZVBlU01QZU9lYXA0QTJpV1ZsakUK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
