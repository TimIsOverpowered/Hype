{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "fs:allow-write-file",
      "allow": [
        { "path": "**" }
      ]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [
        { "path": "**" }
      ]
    },
    {
      "identifier": "fs:allow-stat",
      "allow": [
        { "path": "**" }
      ]
    },
    "dialog:default",
    "http:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://**" },
        { "url": "http://**" }
      ]
    }
  ]
}
